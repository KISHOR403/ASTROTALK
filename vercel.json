{
  "version": 2,
  "experimentalServices": {
    "backend": {
      "root": "backend",
      "framework": "express",
      "entrypoint": "server.js",
      "installCommand": "npm install"
    },
    "frontend": {
      "root": "./",
      "framework": "vite",
      "installCommand": "npm install",
      "buildCommand": "npm run build"
    }
  },
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
